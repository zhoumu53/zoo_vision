{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}"
        },
        {
            "name": "(gdb) Launch zoo_camera",
            "type": "cppdbg",
            "preLaunchTask": "Colcon: build debug",
            "request": "launch",
            "program": "${workspaceFolder}/zoo_vision_ros2/build/zoo_vision/zoo_vision",
            "args": [
                "-c",
                "/enabled_cameras=\\[\\\"zag_elp_cam_016\\\"\\]",
                // "-c",
                // "/video_db=\\\"/media/dherrera/ElephantExternal/elephants/night_sarah/zurich/2023/video_db.json\\\"",
                // "-c",
                // "/replay_time=\\\"2023-08-21T20:32:00\\\"",
                "-c",
                "/record_tracks=false"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(gdb) Launch zoo_rerun",
            "type": "cppdbg",
            "preLaunchTask": "Colcon: build debug",
            "request": "launch",
            "program": "${workspaceFolder}/zoo_vision_ros2/build/zoo_vision/zoo_rerun",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
    ]
}